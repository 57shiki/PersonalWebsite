---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page not found">
  <main
    id="main"
    class="mx-auto flex min-h-screen max-w-5xl flex-col items-center justify-center px-6 text-center"
  >
    <p class="text-accent-strong font-mono text-sm tracking-wide">404</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">
      This page wandered off.
    </h1>
    <p class="text-muted mt-4">
      Probably out taking photos. Let's get you back.
    </p>
    <a
      href="/"
      class="bg-accent text-text mt-8 inline-flex items-center gap-2 rounded-lg px-5 py-2.5 font-medium transition-opacity hover:opacity-90"
    >
      Back home
    </a>
  </main>
</BaseLayout>
