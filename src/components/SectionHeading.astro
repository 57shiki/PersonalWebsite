---
interface Props {
  id: string;
  eyebrow?: string;
  title: string;
}
const { id, eyebrow, title } = Astro.props;
---

<div class="mb-10">
  {
    eyebrow && (
      <p class="text-accent-strong mb-2 font-mono text-sm tracking-wide">
        {eyebrow}
      </p>
    )
  }
  <h2 id={id} class="text-h2">
    {title}
  </h2>
</div>
