---
import { navSections } from "../lib/utils";
import { profile } from "../data/profile";
import ThemeToggle from "./ThemeToggle.tsx";
---

<header
  class="border-border/60 bg-bg/80 supports-[backdrop-filter]:bg-bg/60 sticky top-0 z-40 border-b backdrop-blur"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a href="#top" class="font-mono text-lg font-semibold tracking-tight">
      {profile.shortName.toLowerCase()}<span class="text-accent-strong">.</span>
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {
        navSections.map((s) => (
          <li>
            <a
              href={`#${s.id}`}
              data-nav-link={s.id}
              class="text-muted hover:text-text text-sm transition-colors"
            >
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={profile.resumeUrl}
        class="border-border hover:bg-surface hidden rounded-lg border px-3 py-1.5 text-sm transition-colors sm:inline-block"
      >
        Résumé
      </a>
      <ThemeToggle client:load />
    </div>
  </nav>
</header>

<script>
  // Highlight the nav link for the section currently in view.
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const byId = new Map<string, HTMLAnchorElement>();
  links.forEach((l) => byId.set(l.dataset.navLink!, l));

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          links.forEach((l) => l.classList.remove("text-text", "font-medium"));
          byId.get(entry.target.id)?.classList.add("text-text", "font-medium");
        }
      });
    },
    { rootMargin: "-40% 0px -55% 0px" },
  );

  document.querySelectorAll("section[id]").forEach((s) => observer.observe(s));
</script>
