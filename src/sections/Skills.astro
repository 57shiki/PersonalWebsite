---
import SectionHeading from "../components/SectionHeading.astro";
import TechTag from "../components/TechTag.astro";
import { skills } from "../data/skills";
---

<section id="skills" class="border-border/60 bg-surface/40 border-t">
  <div class="mx-auto max-w-5xl px-6 py-20">
    <SectionHeading id="skills-heading" title="Tools I work with" />

    <div class="grid gap-8 sm:grid-cols-2">
      {
        skills.map((group) => (
          <div>
            <h3 class="text-accent-strong mb-4 font-mono text-sm tracking-wide uppercase">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((item) => (
                <TechTag label={item} />
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
