---
import SectionHeading from "../components/SectionHeading.astro";
import TechTag from "../components/TechTag.astro";
import { projects } from "../data/projects";
import { Github, ExternalLink } from "lucide-react";
---

<section id="projects" class="mx-auto max-w-5xl px-6 py-20">
  <SectionHeading id="projects-heading" title="Things I've built" />

  <div class="grid gap-6 sm:grid-cols-2">
    {
      projects.map((p) => (
        <article
          class:list={[
            "border-border bg-surface/50 flex flex-col rounded-xl border p-6 transition-transform duration-300 hover:-translate-y-1",
            p.featured && "sm:col-span-2",
          ]}
        >
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-lg font-semibold">{p.title}</h3>
            <div class="text-muted flex items-center gap-3">
              {p.repoUrl && (
                <a
                  href={p.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${p.title} on GitHub`}
                  class="hover:text-text transition-colors"
                >
                  <Github size={18} aria-hidden />
                </a>
              )}
              {p.liveUrl && (
                <a
                  href={p.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${p.title} live site`}
                  class="hover:text-text transition-colors"
                >
                  <ExternalLink size={18} aria-hidden />
                </a>
              )}
            </div>
          </div>
          <p class="text-muted mt-3 flex-1">{p.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {p.tech.map((t) => (
              <TechTag label={t} />
            ))}
          </div>
        </article>
      ))
    }
  </div>
</section>
